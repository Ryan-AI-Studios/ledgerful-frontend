{
  "name": "ledgerful-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 52001",
    "build": "node scripts/build-with-csp.mjs",
    "csp:check": "node scripts/check-csp.mjs",
    "start": "next start",
    "lint": "eslint",
    "test:unit": "vitest run",
    "contract:refresh": "node scripts/refresh-openapi.mjs",
    "contract:generate": "node scripts/gen-api-types.mjs",
    "contract:check": "npm run contract:generate && git diff --exit-code src/lib/api/generated.d.ts && node scripts/check-wire-interfaces.mjs",
    "test:telemetry-ingest": "deno test --allow-env supabase/functions/telemetry-ingest/handler_test.ts",
    "check:telemetry-ingest-pins": "node scripts/check-telemetry-ingest-pins.mjs"
  },
  "dependencies": {
    "@playwright/test": "^1.61.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.24.0",
    "next": "16.2.11",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vercel/config": "^0.5.5",
    "eslint": "^10.7.0",
    "eslint-config-next": "16.2.11",
    "jsdom": "^29.1.1",
    "knip": "^6.26.0",
    "openapi-typescript": "7.13.0",
    "parse5": "^8.0.1",
    "supabase": "^2.109.1",
    "tailwindcss": "^4.3.2",
    "typescript": "^5",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "postcss": "^8.5.18",
    "path-to-regexp": "6.3.0",
    "minimatch": "^10.2.3",
    "brace-expansion": "^5.0.8",
    "js-yaml": "^4.3.0",
    "sharp": "^0.35.3",
    "@redocly/openapi-core": {
      "brace-expansion": "^5.0.8",
      "js-yaml": "^4.3.0",
      "minimatch": "^10.2.3"
    }
  }
}
