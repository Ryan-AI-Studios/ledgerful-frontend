# Ledgerful Frontend Environment Variables
# Copy this file to .env.local and fill in values. Never commit real secrets.

# --- Ledgerful local daemon connection ---
# The local Rust daemon runs on port 52001 and exposes endpoints under /api/*.
NEXT_PUBLIC_LEDGERFUL_API_URL=http://127.0.0.1:52001
NEXT_PUBLIC_LEDGERFUL_USE_MOCK=true

# Path to the Ledgerful config file (mirrors the shipped engine v0.1.6).
LEDGERFUL_CONFIG=

# --- Supabase (used for hosted demo / team tier; local-first mode does not require this) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- External LLM / AI services ---
GEMINI_API_KEY=

# --- ai-brains project context (auto-populated by ai-brains context) ---
AI_BRAINS_PROJECT_ID=
AI_BRAINS_SESSION_ID=

# --- Telemetry (opt-in; mirrors the shipped engine v0.1.6) ---
# Official ingest endpoint (coordination.md §6.1). The CLI/engine reads this
# variable when usage telemetry is enabled; default matches the shipped binary.
LEDGERFUL_USAGE_ENDPOINT=https://scmxtnjqqklvcwyeouvj.supabase.co/functions/v1/telemetry-ingest

# --- Frontend auth (operator paste via TokenPrompt; do not commit) ---
# The daemon issues an ephemeral session token (console or --print-token=false file).
# Paste it into the Sign in form. The app keeps it in module memory only (not
# sessionStorage / localStorage / URL). Sign-out and 401/403 clear it.
LEDGERFUL_TOKEN=
