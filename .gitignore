/.claude/
/.ai-brains/

# agent state
.agents/worktrees/
.codex/worktrees/
.agents/review_*.md
.codex/review_*.md
.agents/*.lock
.codex/*.lock

# ledgerful derived state
/.ledgerful/

# Supabase
.supabase/
.branches
.temp

# env files
.env.local
.env.*.local
.env.keys
